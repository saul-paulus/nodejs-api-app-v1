{
    "name": "api-expresjs",
    "version": "1.0.1",
    "description": "start build of api with expresjs",
    "main": "index.js",
    "scripts": {
        "start": "node src/server.js",
        "dev": "nodemon src/server.js",
        "lint": "eslint src",
        "lint:fix": "eslint src --fix",
        "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js -i",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:studio": "prisma studio",
        "prisma:seed": "node prisma/seed/index.seed.js",
        "depcruise": "npx dependency-cruiser --config .dependency-cruiser.js --validate src"
    },
    "jest": {
        "moduleNameMapper": {
            "^@/(.*)$": "<rootDir>/src/$1",
            "^#/(.*)$": "<rootDir>/src/$1"
        },
        "transform": {
            "^.+\\.[t|j]sx?$": "babel-jest"
        },
        "testEnvironment": "node"
    },
    "keywords": [
        "api",
        "nodejs-api",
        "expresjs-api"
    ],
    "author": "saul paulus (Ixspx)",
    "license": "MIT",
    "type": "module",
    "dependencies": {
        "@prisma/client": "^6.19.2",
        "awilix": "^13.0.3",
        "bcrypt": "^6.0.0",
        "cors": "^2.8.6",
        "express": "^5.2.1",
        "helmet": "^8.1.0",
        "http-status-codes": "^2.3.0",
        "joi": "^18.0.2",
        "jsonwebtoken": "^9.0.3",
        "ms": "^2.1.3",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1",
        "winston": "^3.19.0",
        "winston-daily-rotate-file": "^5.0.0"
    },
    "devDependencies": {
        "@babel/preset-env": "^7.29.0",
        "@commitlint/cli": "^20.5.0",
        "@commitlint/config-conventional": "^20.5.0",
        "@jest/globals": "^30.3.0",
        "@types/bcrypt": "^6.0.0",
        "@types/express": "^5.0.6",
        "@types/jest": "^30.0.0",
        "@types/supertest": "^7.2.0",
        "babel-jest": "^30.3.0",
        "dotenv": "^17.3.1",
        "eslint": "^8.57.1",
        "eslint-config-airbnb-base": "^15.0.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-prettier": "^5.5.5",
        "globals": "^17.4.0",
        "husky": "^9.1.7",
        "jest": "^30.3.0",
        "nodemon": "^3.1.14",
        "prettier": "^3.8.1",
        "prisma": "^6.19.2",
        "supertest": "^7.2.2"
    },
    "imports": {
        "#/*": "./src/*"
    }
}
