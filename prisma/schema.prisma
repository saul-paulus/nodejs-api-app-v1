generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DB_URL")
}

model User {
  id          Int      @id @default(autoincrement())
  id_personal String   @unique
  username    String
  password    String
  codeuker    String
  id_wewenang Int
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
}
